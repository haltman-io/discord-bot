{
  "name": "discord-bot-template",
  "version": "1.0.0",
  "description": "Reliable TypeScript Discord bot foundation with JSON configuration.",
  "private": true,
  "license": "MIT",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.18.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "format": "prettier --write .",
    "lint": "eslint .",
    "register": "tsx src/register-commands.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "pm2:start": "npm run build && pm2 start ecosystem.config.cjs",
    "pm2:reload": "npm run build && pm2 reload ecosystem.config.cjs --update-env",
    "pm2:stop": "pm2 stop ecosystem.config.cjs"
  },
  "dependencies": {
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.3.0",
    "pm2": "^7.0.1",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  }
}
